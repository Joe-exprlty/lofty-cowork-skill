# ────────────────────────────────────────────────────────────────
# Lofty + Claude Cowork Starter Kit: Environment Variables
# ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values. The .env file
# stays on this machine only and should be git-ignored. Each
# computer that runs the client needs its own .env.
#
# At minimum, set LOFTY_API_KEY. Everything else is optional.
# ────────────────────────────────────────────────────────────────

# Required: Lofty CRM personal access token (JWT format).
# Get from: app.lofty.com -> Settings -> API Keys -> Generate
# It will be a long string starting with "eyJ".
# Auth header format: "Authorization: token <key>"  (NOT "Bearer")
LOFTY_API_KEY=your-lofty-jwt-here


# ── Optional overrides (defaults work for production) ────────────
# Uncomment and set only if you need to change them.

# Lofty API base URL (almost never changes):
# LOFTY_BASE_URL=https://api.lofty.com

# Seconds between API calls. Lofty's limit is 10 req/min, so 6.5s is
# the safe default. Lower it only if Lofty raises your limit.
# LOFTY_RATE_LIMIT_DELAY=6.5


# ── Owner identity (used by Phase 2 showing helpers) ─────────────
# These let prepare_showing stamp your identity into calendar invites
# and let find_client exclude your own record from name searches.
# Match what's in your CLAUDE.md.

OWNER_FULL_NAME=<Your Name>
OWNER_BROKERAGE=<Your Brokerage>
OWNER_PHONE=<your-phone>
OWNER_EMAIL=<your-email>
OWNER_LAST_NAME_LOWER=<your last name lowercase>
MLS_NAME=<your MLS, e.g. RMLS>

# Optional: shown as a clickable link in the HTML buyer recap email
# signature (jotform-to-lofty Worker). Leave blank to omit the line.
# OWNER_WEBSITE=https://www.example.com


# ── Phase 2: Cloudflare Worker integrations ──────────────────────
# Only needed if you've deployed your own Workers. The Python client
# fails soft when these are blank: find_client and find_listing_by_address
# still work, but prepare_showing skips the SMS / short-link steps.
# See references/extending.md and the Workers setup guide.

# Source for find_client. "worker" reads from a live Worker fed by
# Lofty webhook list 2. Anything else (default) reads from a local
# file built by scripts/refresh_leads_index.py. Start with the file;
# switch to "worker" once you've deployed the leads-index Worker.
# LOFTY_LEADS_INDEX_SOURCE=file

# Override the local file path (default is <repo>/data/leads_index.json):
# LOFTY_LEADS_INDEX_PATH=/absolute/path/to/leads_index.json

# Warn-only threshold for local file age (default 14 days):
# LOFTY_LEADS_INDEX_STALENESS_DAYS=14

# Your leads-index Worker URL:
# LEADS_INDEX_WORKER_URL=https://leads-index.<your-subdomain>.workers.dev

# Bearer token for your leads-index Worker's /export endpoint.
# Generate a random 32-char string; lives in BOTH this .env AND the
# Worker's secret store.
# LEADS_INDEX_EXPORT_API_KEY=your-bearer-token-here

# Webhook secret in your leads-index Worker callback URL. Lofty webhook
# list 2 posts to /webhook/<this_secret>; the Worker rejects anything
# without it. Keep in sync with what the webhook subscription shows.
# LOFTY_WEBHOOK_SECRET=your-webhook-secret-here

# Your short-links Worker URL:
# SHORTENER_BASE_URL=https://short-links.<your-subdomain>.workers.dev

# Bearer token for your short-links Worker:
# SHORTENER_API_KEY=your-shortener-bearer-token-here

# Your showing-sms Worker URL (Durable Objects, $5/mo Workers Paid plan):
# SHOWING_SMS_BASE_URL=https://showing-sms.<your-subdomain>.workers.dev

# The Jotform form ID for your post-showing feedback form. Just the
# numeric ID (not the full URL). Look at your form's URL in Jotform:
# https://www.jotform.com/build/<this-numeric-string>.
# JOTFORM_FORM_ID=<your-jotform-form-id>

# Your jotform-to-lofty Worker URL (handles form submissions and
# serves the /preferences/<leadId> aggregation endpoint):
# JOTFORM_WORKER_URL=https://jotform-to-lofty.<your-subdomain>.workers.dev

# Bearer token for the jotform-to-lofty Worker /preferences endpoint:
# LOFTY_PREFERENCES_API_KEY=your-preferences-bearer-token-here

# Resend API key for the buyer recap email sent by the jotform-to-lofty
# Worker. OPTIONAL: if unset, the Worker falls back to Lofty's
# send_email endpoint to deliver the recap to the lead's primary email
# on file. Set this only if you want the recap to come from your own
# verified sending domain (matching OWNER_EMAIL) and to land at the
# email address the buyer typed into the form.
# RESEND_API_KEY=your-resend-api-key-here

# Cloudflare API token, only needed if you'll deploy Workers via
# wrangler CLI (required for showing-sms; optional for the others).
# Get from: dash.cloudflare.com/profile/api-tokens, "Edit Cloudflare
# Workers" template.
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
